# Fórum Ambição 2030 — Environment Variables Template
# Copy to .env.local and fill in values for local development
# Run: vercel env pull .env.local to pull from Vercel

# OIDC token — auto-managed by Vercel, do NOT set manually
# VERCEL_OIDC_TOKEN=

# Add future env vars here (e.g. analytics, form service, email)
# VITE_ANALYTICS_ID=
